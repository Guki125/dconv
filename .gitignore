# ───────────────────────────────────────────
#  dconv .gitignore
# ───────────────────────────────────────────

# ── Python ───────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
.eggs/
pip-wheel-metadata/
MANIFEST

# ── Virtual environments ──────────────────────
.venv/
venv/
env/
ENV/
.env

# ── Test output & sample files ────────────────
*.pdf
*.docx
*.doc

# Common output dirs
/output/
/out/
/converted/
/test_output/

# ── macOS ─────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Windows ───────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ── Linux ─────────────────────────────────────
*~
.fuse_hidden*
.Trash-*

# ── IDEs ──────────────────────────────────────
.vscode/
*.code-workspace
.idea/
*.iml
*.iws
*.swp
*.swo
Session.vim
*.sublime-project
*.sublime-workspace

# ── LibreOffice temp files ────────────────────
.~lock.*
